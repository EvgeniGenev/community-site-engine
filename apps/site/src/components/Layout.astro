---
import { FONT_OPTIONS, type FontId, type Locale, type Navigation, type Page, type SiteSettings } from "@community-site-engine/shared";
import { findTranslations, getStylesheets } from "../content";

interface Props {
  page: Page;
  settings: SiteSettings;
  navigation: Navigation;
}

const { page, settings, navigation } = Astro.props;
const translations = await findTranslations(page);
const stylesheets = await getStylesheets();
const languages = settings.supportedLanguages ?? [
  { code: "en", name: "English", nativeName: "English" }
];
const defaultLocale = settings.defaultLocale;
const fonts = settings.fonts ?? { default: "universal-serif" as FontId };
const fontStack = (id: FontId | undefined) => FONT_OPTIONS.find((font) => font.id === id)?.stack ?? FONT_OPTIONS[0].stack;
const fontCss = `
  :root {
    --font-default: ${fontStack(fonts.default)};
    --font-page: ${fontStack(fonts.page ?? fonts.default)};
    --font-heading: ${fontStack(fonts.headings ?? fonts.default)};
    --font-navigation: ${fontStack(fonts.navigation ?? fonts.default)};
    --font-event: ${fontStack(fonts.event ?? fonts.default)};
    --font-article: ${fontStack(fonts.article ?? fonts.default)};
    --font-gallery: ${fontStack(fonts.gallery ?? fonts.default)};
    --font-card: ${fontStack(fonts.card ?? fonts.default)};
    --font-cta: ${fontStack(fonts.cta ?? fonts.default)};
  }
`;
const switcherItems = languages.map((language) => {
  const translatedPage = language.code === page.locale ? page : translations.find((item) => item.locale === language.code);
  const slugPath = translatedPage?.slug ? `${translatedPage.slug}/` : "";
  const href = translatedPage ? (language.code === defaultLocale ? `/${slugPath}` : `/${language.code}/${slugPath}`) : "#";
  return { language, href, available: !!translatedPage, active: language.code === page.locale };
});
const htmlLang: Locale = page.locale;
const maxWidth = settings.headerMaxWidth ?? 1160;
const maxCss = `:root { --max: ${maxWidth}px; } body { overflow-x: hidden; }`;
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.seo.title}</title>
    <meta name="description" content={page.seo.description} />
    {settings.siteIcon?.src && <link rel="icon" href={settings.siteIcon.src} />}
    {stylesheets.map((stylesheet) => (
      stylesheet.css.trim() && <style data-cms-css={stylesheet.key} set:html={stylesheet.css} />
    ))}
    <style data-cms-fonts set:html={fontCss} />
    <style data-cms-max set:html={maxCss} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={page.locale === defaultLocale ? "/" : `/${page.locale}/`} aria-label={settings.name}>
        {settings.siteIcon?.src ? <img class="brand-icon" src={settings.siteIcon.src} alt="" /> : <span class="brand-mark">CMS</span>}
        <span class="brand-copy">
          <span class="brand-text">{settings.name}</span>
          {settings.tagline && <span class="brand-tagline">{settings.tagline}</span>}
        </span>
      </a>
      <nav class="main-nav" aria-label="Main navigation">
        {navigation.items.map((item) => (
          <div class="nav-item">
            <a href={item.href}>{item.label}</a>
            {item.children.length > 0 && (
              <div class="nav-dropdown">
                {item.children.map((child) => <a href={child.href}>{child.label}</a>)}
              </div>
            )}
          </div>
        ))}
      </nav>
      <div class="language-switcher" aria-label="Language switcher">
        {switcherItems.map((item) => (
          item.available
            ? <a class={item.active ? "language active" : "language"} href={item.href} aria-current={item.active ? "page" : undefined}>{item.language.code.toUpperCase()}</a>
            : <span class="language disabled" title={`${item.language.name} not available for this page`}>{item.language.code.toUpperCase()}</span>
        ))}
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-left">
          <h3>Subscribe to our newsletter</h3>
          <form class="newsletter-form">
            <input type="email" placeholder="Enter your email address" required />
            <div class="checkbox-container">
              <input type="checkbox" id="subscribe-check" />
              <label for="subscribe-check">Yes, subscribe me to your newsletter</label>
            </div>
          </form>
        </div>
        <div class="footer-right">
          <div class="footer-social">
            <h3>Follow us on</h3>
            <div class="social-icons">
              <a href="https://facebook.com/bhcaz" aria-label="Facebook">
                <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M12 2.04c-5.5 0-10 4.49-10 10.02c0 5 3.66 9.15 8.44 9.9v-7h-2.54v-2.9h2.54V9.85c0-2.51 1.49-3.89 3.77-3.89c1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.53-4.5-10.02-10-10.02Z"/></svg>
              </a>
              <a href="https://instagram.com/bhcaz" aria-label="Instagram">
                <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8A3.6 3.6 0 0 0 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6A3.6 3.6 0 0 0 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8a1.25 1.25 0 0 1-1.25-1.25a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5a5 5 0 0 1-5 5a5 5 0 0 1-5-5a5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3Z"/></svg>
              </a>
            </div>
          </div>
          <div class="footer-contact">
            <h3>Contact us</h3>
            <a href="mailto:info@bhcaz.com" class="mail-link" aria-label="Email us">
              <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2m0 4l-8 5l-8-5V6l8 5l8-5v2Z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
