---
import type { Article, Event, MediaRef, PageBlock, PageLayout } from "@community-site-engine/shared";

interface Props {
  blocks: PageBlock[];
  layout?: PageLayout;
  events: Event[];
  articles: Article[];
  galleryItems: MediaRef[];
  eventTimeZone: string;
  locale?: string;
}

const { blocks, layout, events, articles, galleryItems, eventTimeZone, locale = "en" } = Astro.props;
const activeLayout = layout ?? { columns: [{ id: "main", label: "Main", width: 100 }] };
const hasMultiColumnLayout = activeLayout.columns.length > 1;
const columnIds = new Set(activeLayout.columns.map((column) => column.id));
const pageGridStyle = `--page-columns: ${activeLayout.columns.map((column) => `${column.width}fr`).join(" ")};`;

function escapeHtml(value: string) {
  return value.replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;");
}

function escapeAttribute(value: string) {
  return escapeHtml(value).replaceAll("\"", "&quot;");
}

function safeMarkdownHref(value: string) {
  const trimmed = value.trim();
  if (trimmed.startsWith("#")) return trimmed;
  if (trimmed.startsWith("/") && !trimmed.startsWith("//")) return trimmed;
  if (!/^[a-zA-Z][a-zA-Z0-9+.-]*:/.test(trimmed)) return trimmed.includes(":") ? "" : trimmed;
  try {
    const parsed = new URL(trimmed);
    return parsed.protocol === "http:" || parsed.protocol === "https:" || parsed.protocol === "mailto:" ? trimmed : "";
  } catch {
    return "";
  }
}

function inlineMarkdown(value: string) {
  return value
    .replace(/&(?![a-zA-Z0-9#]+;)/g, "&amp;")
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/\*(.+?)\*/g, "<em>$1</em>")
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, label: string, href: string) => {
      const safeHref = safeMarkdownHref(href);
      return safeHref ? `<a href="${escapeAttribute(safeHref)}">${label}</a>` : label;
    });
}

function markdownToHtml(body?: string) {
  const lines = (body ?? "").split("\n");
  const html: string[] = [];
  let listOpen = false;
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) {
      if (listOpen) {
        html.push("</ul>");
        listOpen = false;
      }
      continue;
    }
    if (trimmed.startsWith("### ")) {
      if (listOpen) html.push("</ul>");
      listOpen = false;
      html.push(`<h3>${inlineMarkdown(trimmed.slice(4))}</h3>`);
    } else if (trimmed.startsWith("## ")) {
      if (listOpen) html.push("</ul>");
      listOpen = false;
      html.push(`<h2>${inlineMarkdown(trimmed.slice(3))}</h2>`);
    } else if (trimmed.startsWith("- ")) {
      if (!listOpen) {
        html.push("<ul>");
        listOpen = true;
      }
      html.push(`<li>${inlineMarkdown(trimmed.slice(2))}</li>`);
    } else {
      if (listOpen) html.push("</ul>");
      listOpen = false;
      html.push(`<p>${inlineMarkdown(trimmed)}</p>`);
    }
  }
  if (listOpen) html.push("</ul>");
  return html.join("");
}

function datePart(value: string, type: string, formatOptions: Intl.DateTimeFormatOptions = {}) {
  const parts = new Intl.DateTimeFormat("en-US", {
    timeZone: eventTimeZone,
    ...formatOptions
  }).formatToParts(new Date(value));
  return parts.find((item) => item.type === type)?.value ?? "";
}

function eventDateKey(value: string) {
  const year = datePart(value, "year", { year: "numeric", month: "2-digit", day: "2-digit" });
  const month = datePart(value, "month", { year: "numeric", month: "2-digit", day: "2-digit" });
  const day = datePart(value, "day", { year: "numeric", month: "2-digit", day: "2-digit" });
  return `${year}-${month}-${day}`;
}

function formatDate(value: string) {
  return new Intl.DateTimeFormat("en-US", { dateStyle: "medium", timeStyle: "short", timeZone: eventTimeZone }).format(new Date(value));
}

function blockStyle(block: PageBlock) {
  const base = block.customCss ?? "";
  if (!hasMultiColumnLayout) return base;
  const requestedColumn = block.layoutColumn && columnIds.has(block.layoutColumn) ? block.layoutColumn : activeLayout.columns[0]?.id;
  const columnIndex = Math.max(0, activeLayout.columns.findIndex((column) => column.id === requestedColumn));
  return `${base}${base.trim().endsWith(";") || !base.trim() ? "" : ";"} grid-column: ${columnIndex + 1};`;
}

function eventHref(event: Event) {
  return locale === "en" ? `/events/${event.slug}/` : `/${locale}/sabitiya/${event.slug}/`;
}

function truncate(text: string, max = 120) {
  return text.length <= max ? text : text.slice(0, max).replace(/\s+\S*$/, "") + "…";
}

const galleryScripts: string[] = [];
const eventScripts: string[] = [];
const articleScripts: string[] = [];
---
<div class:list={["page-layout", { "page-layout--single": !hasMultiColumnLayout }]} data-columns={activeLayout.columns.length} style={pageGridStyle}>
{blocks.map((block) => {
  if (block.type === "hero") {
    return (
      <section class="hero section" style={blockStyle(block)}>
        <div class="hero-copy">
          {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
          <h1>{block.title}</h1>
          {block.body && <p class="lede">{block.body}</p>}
          {block.actions.length > 0 && (
            <div class="actions">
              {block.actions.map((action) => <a class={`button ${action.variant}`} href={action.href}>{action.label}</a>)}
            </div>
          )}
        </div>
        {block.image && <img class="hero-image" src={block.image.src} alt={block.image.alt} />}
      </section>
    );
  }

  if (block.type === "richText") {
    return (
      <section class="section prose" style={blockStyle(block)}>
        {block.title && <h2>{block.title}</h2>}
        <div set:html={markdownToHtml(block.body)} />
      </section>
    );
  }

  if (block.type === "cardGrid") {
    return (
      <section class="section" style={blockStyle(block)}>
        {block.title && <h2>{block.title}</h2>}
        {block.intro && <p class="section-intro">{block.intro}</p>}
        <div class="card-grid">
          {block.cards.map((card) => (
            <article class="card">
              {card.image && <img src={card.image.src} alt={card.image.alt} />}
              <h3>{card.title}</h3>
              <p>{card.body}</p>
              {card.href && <a href={card.href}>Read more</a>}
            </article>
          ))}
        </div>
      </section>
    );
  }

  if (block.type === "gallery") {
    const galleryId = `gallery-${galleryScripts.length}`;
    galleryScripts.push(galleryId);
    const items = galleryItems.length ? galleryItems : block.items;
    return (
      <section class="section gallery-shell" data-gallery-root={galleryId} style={blockStyle(block)}>
        {block.title && <h2>{block.title}</h2>}
        {block.intro && <p class="section-intro">{block.intro}</p>}
        <div class="gallery-grid">
          {items.map((item, index) => (
            <figure data-gallery-item data-page={Math.floor(index / 9) + 1}>
              <button type="button" class="gallery-open" data-src={item.src} data-alt={item.alt} data-caption={item.caption ?? item.description ?? ""}>
                <img src={item.src} alt={item.alt} loading="lazy" />
              </button>
              {item.caption && <figcaption>{item.caption}</figcaption>}
            </figure>
          ))}
        </div>
        <div class="gallery-pagination" aria-label="Gallery pagination"></div>
        <dialog class="gallery-dialog" aria-label="Image preview">
          <button type="button" class="dialog-close" aria-label="Close image preview">Close</button>
          <img src="" alt="" />
          <p></p>
        </dialog>
      </section>
    );
  }

  if (block.type === "eventList") {
    const selectedEvents = (block.eventIds.length ? events.filter((event) => block.eventIds.includes(event.id)) : events)
      .slice()
      .sort((a, b) => new Date(b.startsAt).getTime() - new Date(a.startsAt).getTime());
    const calendarEvents = selectedEvents.map((event) => ({ ...event, dateKey: eventDateKey(event.startsAt) }));
    const eventsId = `events-${eventScripts.length}`;
    eventScripts.push(eventsId);
    return (
      <section class="section events-calendar-shell" data-events-root={eventsId} data-events={JSON.stringify(calendarEvents)} data-time-zone={eventTimeZone} style={blockStyle(block)}>
        {block.title && <h2>{block.title}</h2>}
        {block.intro && <p class="section-intro">{block.intro}</p>}
        {block.showCalendar !== false ? (
          <div class="events-workspace">
            <aside class="calendar-panel" style="min-width:0;overflow:hidden;">
              <div class="calendar-toolbar">
                <button type="button" data-calendar-prev>Prev</button>
                <strong data-calendar-title></strong>
                <button type="button" data-calendar-next>Next</button>
                <button type="button" data-calendar-today>Current</button>
              </div>
              <div class="calendar-grid" data-calendar-grid aria-label="Events calendar"></div>
            </aside>
            <div class="event-list" data-event-list style="min-width:0;">
            {selectedEvents.map((event) => (
              <article class="event-card" data-event-card data-date={eventDateKey(event.startsAt)}>
                <div class="date-box">
                  <span>{datePart(event.startsAt, "month", { month: "short", day: "2-digit" })}</span>
                  <strong>{Number(datePart(event.startsAt, "day", { month: "short", day: "2-digit" }))}</strong>
                </div>
                <div class="event-card-body">
                  {event.image?.src && <img class="event-card-img" src={event.image.src} alt={event.image.alt} loading="lazy" />}
                  <h3>{event.title}</h3>
                  <p class="meta">{formatDate(event.startsAt)}{event.address ? ` · ${event.address}` : ""}</p>
                  <p>{truncate(event.description)}</p>
                  <a href={eventHref(event)} class="event-see-more">{locale === "en" ? "See more →" : "Виж повече →"}</a>
                </div>
              </article>
            ))}
              <p class="empty-events" data-empty-events hidden>No events scheduled for this date.</p>
            </div>
          </div>
        ) : (
          <div class="event-list" data-event-list>
          {selectedEvents.map((event) => (
            <article class="event-card" data-event-card data-date={eventDateKey(event.startsAt)}>
              <div class="date-box">
                <span>{datePart(event.startsAt, "month", { month: "short", day: "2-digit" })}</span>
                <strong>{Number(datePart(event.startsAt, "day", { month: "short", day: "2-digit" }))}</strong>
              </div>
              <div class="event-card-body">
                {event.image?.src && <img class="event-card-img" src={event.image.src} alt={event.image.alt} loading="lazy" />}
                <h3>{event.title}</h3>
                <p class="meta">{formatDate(event.startsAt)}{event.address ? ` · ${event.address}` : ""}</p>
                <p>{truncate(event.description)}</p>
                <a href={eventHref(event)} class="event-see-more">{locale === "en" ? "See more →" : "Виж повече →"}</a>
              </div>
            </article>
          ))}
          </div>
        )}
      </section>
    );
  }

  if (block.type === "articleList") {
    const selectedArticles = block.articleIds.length ? articles.filter((article) => block.articleIds.includes(article.id)) : articles;
    if (selectedArticles.length > 0) articleScripts.push("loaded");
    return (
      <section class="section article-list-block" style={blockStyle(block)}>
        {block.title && <h2>{block.title}</h2>}
        {block.intro && <p class="section-intro">{block.intro}</p>}
        <div class="article-list-feed" data-article-feed>
          {selectedArticles.map((article, index) => {
            const href = locale === "en" ? `/news-articles/${article.slug}/` : `/${locale}/novini-i-statii/${article.slug}/`;
            const isMatch = index < 3;
            return (
              <article class="card article article--horizontal" data-article-page={Math.floor(index / 3)} hidden={!isMatch} style={`display:${isMatch ? "flex" : "none"};gap:24px;align-items:flex-start;margin-bottom:24px;text-align:left;`}>
                {article.featuredImage?.src && (
                  <div class="article-img-wrapper" style="flex:0 0 160px;max-width:160px;">
                    <img src={article.featuredImage.src} alt={article.featuredImage.alt} loading="lazy" style="width:100%;height:120px;object-fit:cover;border-radius:12px;" />
                  </div>
                )}
                <div class="article-content" style="flex:1;min-width:0;">
                  <p class="eyebrow" style="margin-bottom:4px;">{article.category} · {article.date}</p>
                  <h3 style="margin:0 0 8px;"><a href={href} style="color:inherit;text-decoration:none;">{article.title}</a></h3>
                  <p class="snippet" style="margin:0 0 12px;color:var(--muted);font-size:15px;line-height:1.5;">{article.excerpt}</p>
                  <a href={href} class="read-more-link" style="font-weight:600;font-size:15px;">{locale === "en" ? "Read more →" : "Прочети повече →"}</a>
                </div>
              </article>
            );
          })}
        </div>
        {selectedArticles.length > 3 && (
          <div class="pager-controls" data-article-pager data-total-pages={Math.ceil(selectedArticles.length / 3)} style="display:flex;align-items:center;justify-content:center;gap:16px;margin-top:32px;">
            <button type="button" class="button secondary" data-pager-prev disabled style="padding:8px 16px;">← {locale === "en" ? "Previous" : "Предишна"}</button>
            <span class="pager-status" style="font-size:15px;font-weight:500;"><span data-pager-current>1</span> / {Math.ceil(selectedArticles.length / 3)}</span>
            <button type="button" class="button secondary" data-pager-next style="padding:8px 16px;">{locale === "en" ? "Next" : "Следваща"} →</button>
          </div>
        )}
      </section>
    );
  }

  if (block.type === "cta") {
    return (
      <section class="section cta" style={blockStyle(block)}>
        <h2>{block.title}</h2>
        {block.body && <p>{block.body}</p>}
        <div class="actions">
          {block.actions.map((action) => <a class={`button ${action.variant}`} href={action.href}>{action.label}</a>)}
        </div>
      </section>
    );
  }

  if (block.type === "fileList") {
    const localizeFileItem = (item: any) => {
      if (locale === "en") return item;
      const t = item.translations?.[locale];
      return {
        ...item,
        label: t?.label?.trim() ? t.label : item.label,
        description: t?.description?.trim() ? t.description : item.description
      };
    };
    return (
      <section class="section file-list-block" style={blockStyle(block)}>
        {block.title && <h2 class="file-list-heading">{block.title}</h2>}
        {block.intro && <p class="section-intro">{block.intro}</p>}
        <ul class="file-list">
          {block.files.map((rawItem) => {
            const item = localizeFileItem(rawItem);
            const ext = item.src.split(".").pop()?.toUpperCase() ?? "FILE";
            return (
              <li class="file-item">
                <a class="file-link" href={item.src} target="_blank" rel="noopener noreferrer" download>
                  <span class="file-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                      <polyline points="14 2 14 8 20 8"/>
                    </svg>
                  </span>
                  <span class="file-label">{item.label}</span>
                  <span class="file-ext">{ext}</span>
                </a>
                {item.description && <p class="file-description">{item.description}</p>}
              </li>
            );
          })}
        </ul>
      </section>
    );
  }

})}
</div>

{galleryScripts.length > 0 && (
  <script is:inline>
    document.querySelectorAll("[data-gallery-root]").forEach((root) => {
      const items = Array.from(root.querySelectorAll("[data-gallery-item]"));
      const pagination = root.querySelector(".gallery-pagination");
      const dialog = root.querySelector(".gallery-dialog");
      const dialogImage = dialog?.querySelector("img");
      const dialogCaption = dialog?.querySelector("p");
      const close = dialog?.querySelector(".dialog-close");
      let page = 1;
      const pages = Math.max(1, Math.ceil(items.length / 9));

      function render() {
        items.forEach((item) => {
          item.hidden = Number(item.dataset.page) !== page;
        });
        if (!pagination) return;
        pagination.innerHTML = "";
        for (let i = 1; i <= pages; i += 1) {
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = String(i);
          button.className = i === page ? "active" : "";
          button.setAttribute("aria-label", `Show gallery page ${i}`);
          button.addEventListener("click", () => {
            page = i;
            render();
          });
          pagination.append(button);
        }
      }

      root.querySelectorAll(".gallery-open").forEach((button) => {
        button.addEventListener("click", () => {
          if (!dialog || !dialogImage || !dialogCaption) return;
          dialogImage.src = button.dataset.src || "";
          dialogImage.alt = button.dataset.alt || "";
          dialogCaption.textContent = button.dataset.caption || button.dataset.alt || "";
          dialog.showModal();
        });
      });

      close?.addEventListener("click", () => dialog?.close());
      dialog?.addEventListener("click", (event) => {
        if (event.target === dialog) dialog.close();
      });
      render();
    });
  </script>
)}

{eventScripts.length > 0 && (
  <script is:inline>
    document.querySelectorAll("[data-events-root]").forEach((root) => {
      const events = JSON.parse(root.dataset.events || "[]");
      const timeZone = root.dataset.timeZone || "America/Phoenix";
      const title = root.querySelector("[data-calendar-title]");
      const grid = root.querySelector("[data-calendar-grid]");
      const cards = Array.from(root.querySelectorAll("[data-event-card]"));
      const empty = root.querySelector("[data-empty-events]");
      const today = new Date();
      const todayKey = dateKeyInTimeZone(today, timeZone);
      let cursor = monthFromKey(events[0]?.dateKey || todayKey);
      const eventDates = new Set(events.map((event) => event.dateKey || event.startsAt.slice(0, 10)));

      function dateKeyInTimeZone(date, zone) {
        const parts = new Intl.DateTimeFormat("en-US", { timeZone: zone, year: "numeric", month: "2-digit", day: "2-digit" }).formatToParts(date);
        const part = (type) => parts.find((item) => item.type === type)?.value || "";
        return `${part("year")}-${part("month")}-${part("day")}`;
      }

      function monthFromKey(key) {
        const [year, month] = key.split("-").map(Number);
        return new Date(year, month - 1, 1);
      }

      function dateKey(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        return `${year}-${month}-${day}`;
      }

      function filter(date) {
        let visible = 0;
        cards.forEach((card) => {
          const match = !date || card.dataset.date === date;
          card.hidden = !match;
          if (match) visible += 1;
        });
        if (empty) empty.hidden = visible > 0;
      }

      function renderCalendar() {
        if (!grid || !title) return;
        title.textContent = cursor.toLocaleString("en-US", { month: "long", year: "numeric" });
        grid.innerHTML = "";
        ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"].forEach((day) => {
          const label = document.createElement("span");
          label.className = "calendar-weekday";
          label.textContent = day;
          grid.append(label);
        });
        const first = new Date(cursor.getFullYear(), cursor.getMonth(), 1);
        const start = new Date(first);
        start.setDate(first.getDate() - first.getDay());
        for (let i = 0; i < 42; i += 1) {
          const date = new Date(start);
          date.setDate(start.getDate() + i);
          const key = dateKey(date);
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = String(date.getDate());
          button.className = date.getMonth() !== cursor.getMonth() ? "muted" : "";
          if (eventDates.has(key)) button.classList.add("has-event");
          if (key === todayKey) button.classList.add("is-today");
          button.addEventListener("click", () => filter(key));
          grid.append(button);
        }
      }

      root.querySelector("[data-calendar-prev]")?.addEventListener("click", () => {
        cursor = new Date(cursor.getFullYear(), cursor.getMonth() - 1, 1);
        renderCalendar();
      });
      root.querySelector("[data-calendar-next]")?.addEventListener("click", () => {
        cursor = new Date(cursor.getFullYear(), cursor.getMonth() + 1, 1);
        renderCalendar();
      });
      root.querySelector("[data-calendar-today]")?.addEventListener("click", () => {
        cursor = monthFromKey(todayKey);
        renderCalendar();
        filter(null);
      });
      renderCalendar();
      filter(null);
    });
  </script>
)}

{articleScripts.length > 0 && (
  <script is:inline>
    document.querySelectorAll("[data-article-pager]").forEach((pager) => {
      const section = pager.closest(".article-list-block") || document;
      const cards = section.querySelectorAll("[data-article-page]");
      const prevBtn = pager.querySelector("[data-pager-prev]");
      const nextBtn = pager.querySelector("[data-pager-next]");
      const currentSpan = pager.querySelector("[data-pager-current]");
      const totalPages = Number(pager.dataset.totalPages || 1);
      let currentPage = 0;

      function update() {
        cards.forEach((card) => {
          const match = Number(card.dataset.articlePage) === currentPage;
          card.hidden = !match;
          card.style.display = match ? "flex" : "none";
        });
        if (currentSpan) currentSpan.textContent = String(currentPage + 1);
        if (prevBtn) prevBtn.disabled = currentPage === 0;
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages - 1;
      }

      prevBtn?.addEventListener("click", () => {
        if (currentPage > 0) {
          currentPage -= 1;
          update();
        }
      });

      nextBtn?.addEventListener("click", () => {
        if (currentPage < totalPages - 1) {
          currentPage += 1;
          update();
        }
      });
    });
  </script>
)}
