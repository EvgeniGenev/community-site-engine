---
import Layout from "../../components/Layout.astro";
import { getLocalizedEvents, getNavigation, getSettings } from "../../content";

export async function getStaticPaths() {
  const events = await getLocalizedEvents("en");
  return events.filter((e) => e.status === "published").map((event) => ({
    params: { slug: event.slug }
  }));
}

const { slug } = Astro.params;
const settings = await getSettings();
const navigation = await getNavigation("en");
const events = await getLocalizedEvents("en");
const event = events.find((e) => e.slug === slug);
if (!event) return Astro.redirect("/404.html", 302);

const timeZone = settings.eventTimeZone ?? "America/Phoenix";
const formatDate = (value: string) =>
  new Intl.DateTimeFormat("en-US", { dateStyle: "long", timeStyle: "short", timeZone }).format(new Date(value));

const fakePage = {
  id: event.id,
  locale: "en" as const,
  status: "published" as const,
  title: event.title,
  slug: `events/${event.slug}`,
  translationKey: `event-${event.id}`,
  seo: {
    title: `${event.title} | ${settings.name}`,
    description: event.description.slice(0, 160)
  },
  layout: { columns: [{ id: "main", label: "Main", width: 100 }] },
  blocks: []
};
---
<Layout page={fakePage} settings={settings} navigation={navigation}>
  <div class="section event-detail">
    {event.image?.src && (
      <div class="event-detail-image">
        <img src={event.image.src} alt={event.image.alt} />
      </div>
    )}
    <h1 class="event-detail-title">{event.title}</h1>
    <p class="meta event-detail-meta">
      {formatDate(event.startsAt)}
      {event.endsAt && ` – ${formatDate(event.endsAt)}`}
      {event.address && ` · ${event.address}`}
    </p>
    <div class="event-detail-body">
      <p>{event.description}</p>
      {event.notes && <p><strong>Note:</strong> {event.notes}</p>}
    </div>
    <a href="/events/" class="button primary event-back-link">← Back to Events</a>
  </div>
</Layout>

<style>
  .event-detail {
    max-width: 860px;
    margin: 0 auto;
    padding-top: 48px;
    padding-bottom: 72px;
  }
  .event-detail-image img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: 24px;
    margin-bottom: 32px;
    box-shadow: 0 16px 48px rgba(35,31,32,.14);
  }
  .event-detail-title {
    font-size: clamp(28px, 5vw, 52px);
    margin: 0 0 12px;
  }
  .event-detail-meta {
    margin-bottom: 24px;
    font-size: 16px;
  }
  .event-detail-body p {
    font-size: 18px;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .event-back-link {
    display: inline-flex;
    margin-top: 32px;
  }
</style>
