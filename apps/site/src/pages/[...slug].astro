---
import Blocks from "../components/Blocks.astro";
import Layout from "../components/Layout.astro";
import { getArticles, getGallery, getLocalizedEvents, getNavigation, getPages, getSettings } from "../content";

export async function getStaticPaths() {
  const pages = (await getPages("en")).filter((page) => page.slug !== "");
  return pages.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const settings = await getSettings();
const navigation = await getNavigation("en");
const events = await getLocalizedEvents("en");
const articles = await getArticles("en");
const galleryItems = await getGallery("en");
---
<Layout page={page} settings={settings} navigation={navigation}>
  <Blocks blocks={page.blocks} events={events} articles={articles} galleryItems={galleryItems} eventTimeZone={settings.eventTimeZone} />
</Layout>
