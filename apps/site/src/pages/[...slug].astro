---
import Blocks from "../components/Blocks.astro";
import Layout from "../components/Layout.astro";
import { getArticles, getGallery, getLocalizedEvents, getNavigation, getPage, getPages, getSettings } from "../content";

export async function getStaticPaths() {
  const pages = (await getPages("en")).filter((page) => page.slug !== "");
  return pages.map((page) => ({ params: { slug: page.slug } }));
}

const slug = Array.isArray(Astro.params.slug) ? Astro.params.slug.join("/") : Astro.params.slug ?? "";
const page = await getPage("en", slug);
if (!page) return Astro.redirect("/404.html", 302);
const settings = await getSettings();
const navigation = await getNavigation("en");
const events = await getLocalizedEvents("en");
const articles = await getArticles("en");
const galleryItems = await getGallery("en");
---
<Layout page={page} settings={settings} navigation={navigation}>
  <div class="mini-hero section">
    <div class="mini-hero-left">
      {page.miniHero || page.title}
    </div>
    <div class="mini-hero-right"></div>
  </div>
  <Blocks blocks={page.blocks} layout={page.layout} events={events} articles={articles} galleryItems={galleryItems} eventTimeZone={settings.eventTimeZone} locale={page.locale} contactFormEnabled={settings.contactFormEnabled ?? false} />
</Layout>
