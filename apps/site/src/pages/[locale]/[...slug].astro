---
import Blocks from "../../components/Blocks.astro";
import Layout from "../../components/Layout.astro";
import { getArticles, getContentLocales, getGallery, getLocalizedEvents, getNavigation, getPage, getPages, getSettings } from "../../content";

export async function getStaticPaths() {
  const locales = (await getContentLocales()).filter((locale) => locale !== "en");
  const pages = (await Promise.all(locales.map((locale) => getPages(locale)))).flat().filter((page) => page.slug !== "");
  return pages.map((page) => ({ params: { locale: page.locale, slug: page.slug } }));
}

const locale = Astro.params.locale ?? "en";
const slug = Array.isArray(Astro.params.slug) ? Astro.params.slug.join("/") : Astro.params.slug ?? "";
const page = await getPage(locale, slug);
if (!page) return Astro.redirect("/404.html", 302);
const settings = await getSettings();
const navigation = await getNavigation(page.locale);
const events = await getLocalizedEvents(page.locale);
const articles = await getArticles(page.locale);
const galleryItems = await getGallery(page.locale);
---
<Layout page={page} settings={settings} navigation={navigation}>
  <Blocks blocks={page.blocks} layout={page.layout} events={events} articles={articles} galleryItems={galleryItems} eventTimeZone={settings.eventTimeZone} locale={page.locale} />
</Layout>
